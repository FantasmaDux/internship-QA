<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">

    <property name="charset" value="UTF-8"/>

    <property name="severity" value="${org.checkstyle.google.severity}" default="warning"/>

    <!--        Проверяет, чтобы длина строки не превышала 100 символов-->
    <module name="LineLength">
        <property name="max" value="100"/>
    </module>

    <module name="TreeWalker">
        <!--        Проверяет пробелы до и после операндов и операторов, зарезервированных слов-->
        <module name="WhitespaceAround"/>
        <!--        Проверяет на наличие лишних импортов-->
        <module name="UnusedImports"/>
        <!--        Требует нотации PascalCase-->
        <module name="TypeName"/>
        <!--        Проверяет имена методов. Требует нотации CamelCase-->
        <module name="MethodName"/>
        <!--        Запрещает объявлять несколько переменных в одной строке-->
        <module name="MultipleVariableDeclarations"/>
        <!--        Проверяет стиль объявления массивов-->
        <module name="ArrayTypeStyle"/>
        <!--        Проверяет, чтобы в Long суффикс L был написан в верхнем регистре-->
        <module name="UpperEll"/>
        <!--        Проверяет порядок модификаторов-->
        <module name="ModifierOrder"/>
        <!--        В именах пакетов допустимы только строчные буквы-->
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
            <message key="name.invalidPattern"
                     value="Package name ''{0}'' must match pattern ''{1}''."/>
        </module>
        <!--        В именах локальных переменных camelCase или нижние подчеркивания-->
        <module name="LocalVariableName">
            <property name="format" value="^(_|[a-z]([a-z0-9][a-zA-Z0-9]*)?)$"/>
            <message key="name.invalidPattern"
                     value="Local variable name ''{0}'' must match pattern ''{1}''."/>
        </module>
    </module>
</module>